# ── App ──────────────────────────────────────────────────────────────
APP_NAME=whatsapp-stock-bot
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=dev-local-secret-key-replace-in-production-1234567890

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:root@localhost:5432/stockdb
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ───────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── WhatsApp Cloud API ───────────────────────────────────────────────
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_CHANNEL_ID=
WHATSAPP_RATE_LIMIT=80
WHATSAPP_RATE_WINDOW=60

# ── LLM (OpenAI) for summary enrichment ───────────────────────────────
LLM_ENABLED=false
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=15

# ── NSE / BSE ────────────────────────────────────────────────────────
FETCH_INTERVAL_SECONDS=60
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# ── Alerting (optional) ─────────────────────────────────────────────
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
